---
const stats = [
  { value: '500', label: 'Founding member spots' },
  { value: 'Nationwide', label: 'Survivor-built network' },
  { value: 'By & for', label: 'Disaster survivors' },
];
---

<section class="border-y border-ink/10 bg-ink text-white">
  <div class="mx-auto grid max-w-7xl grid-cols-1 divide-y divide-white/10 sm:grid-cols-3 sm:divide-x sm:divide-y-0">
    {
      stats.map((s) => (
        <div class="px-6 py-8 text-center">
          <div class="stat-value ty-h2">{s.value}</div>
          <div class="mt-2 ty-eyebrow text-white/70">{s.label}</div>
        </div>
      ))
    }
  </div>
</section>
