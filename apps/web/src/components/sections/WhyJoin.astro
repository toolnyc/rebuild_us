---
import { urlFor } from '../../lib/sanity';

interface Row {
  title?: string;
  body?: string;
}

interface Props {
  label?: string;
  columns?: Row[];
  bgImage?: any;
}

const { columns = [], bgImage } = Astro.props;

const bgUrl = bgImage
  ? urlFor(bgImage).width(1600).height(900).fit('crop').url()
  : null;
---

<section id="membership-benefits" class="scroll-mt-20 relative overflow-hidden">
  {bgUrl ? (
    <img
      src={bgUrl}
      alt={bgImage?.alt ?? ''}
      class="absolute inset-0 w-full h-full object-cover"
      aria-hidden={!bgImage?.alt}
    />
  ) : (
    <div class="absolute inset-0 bg-ink"></div>
  )}
  <div class="absolute inset-0 bg-black/55"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 py-20 lg:py-28">
    <h2 class="mb-14 ty-h2 text-center text-white" data-animate="fade">
      Why join Rebuild today?
    </h2>

    <div data-animate-group>
      {columns.map((row) => (
        <div
          class="border-t border-accent-yellow grid grid-cols-1 gap-4 py-10 md:grid-cols-[2fr_3fr] md:gap-16 md:py-12"
          data-animate="fade"
        >
          <h3 class="ty-h2 text-white">{row.title}</h3>
          <p class="ty-lead text-white/75 md:self-center">{row.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
