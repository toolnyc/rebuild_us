---
import { urlFor } from '../../lib/sanity';

interface Column {
  title?: string;
  body?: string;
  image?: any;
  backgroundColor?: string;
}

interface Props {
  label?: string;
  columns?: Column[];
}

const { label, columns = [] } = Astro.props;
---

<section id="membership-benefits" class="scroll-mt-20 mx-auto max-w-7xl px-6 py-20 lg:py-28">
  <h2 class="mb-12 ty-h2 text-center" data-animate="fade">Why join Rebuild today?</h2>
  <div class="grid gap-6 md:grid-cols-3" data-animate-group>
    {
      columns.map((col) => {
        const imageUrl = col.image ? urlFor(col.image).width(782).height(460).fit('crop').url() : null;
        return (
          <article
            class="flex flex-col overflow-hidden border-2 border-accent-orange rounded-[var(--radius)]"
            data-animate="fade"
          >
            {imageUrl ? (
              <img
                src={imageUrl}
                alt={col.title ?? ''}
                class="w-full object-cover"
                style="aspect-ratio:391/230;"
              />
            ) : (
              <div
                class="flex w-full items-center justify-center bg-muted/10 ty-body text-muted"
                style="aspect-ratio:391/230;"
              >
                Image
              </div>
            )}
            <div class="border-t border-ink"></div>
            <div class="flex flex-1 flex-col gap-3 p-6">
              <h3 class="ty-h3">{col.title}</h3>
              <p class="ty-body text-center">{col.body}</p>
            </div>
          </article>
        );
      })
    }
  </div>
</section>
