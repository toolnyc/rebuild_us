---
import TornEdge from '../TornEdge.astro';
import RichText from '../RichText.astro';
import DocumentIcon from '../DocumentIcon.astro';

interface ResourceItem {
  title?: string;
  section?: string;
  fileUrl?: string | null;
}

interface Props {
  label?: string;
  headline?: string;
  subcopy?: any;
  leftCopy?: string;
  items?: ResourceItem[];
  resourcesPageVisible?: boolean;
}

const {
  label,
  headline,
  subcopy,
  leftCopy,
  items: itemsProp,
  resourcesPageVisible = false,
} = Astro.props;

const items = itemsProp ?? [];

const leftCopyHtml =
  leftCopy && resourcesPageVisible
    ? leftCopy.replace(
        /rebuild\.us\/resources/,
        '<a href="/resources" class="link-alt underline">rebuild.us/resources</a>',
      )
    : leftCopy;

type Section = 'disaster-tipsheets' | 'survivors-communities' | 'fema-government' | 'insurance';
---

<div>
  <section
    id="resources"
    class="scroll-mt-20 bg-accent-sage"
  >
    <div class="mx-auto grid max-w-7xl gap-12 px-6 py-16 lg:grid-cols-2 lg:py-24">
      <div data-animate="fade">
        {headline && <h2 class="ty-h2">{headline}</h2>}
        <div class="mt-6 ty-lead [&_mark]:box-decoration-clone">
          <RichText value={subcopy} />
        </div>
        {
          leftCopyHtml && (
            <p class="mt-6 ty-body" set:html={leftCopyHtml} />
          )
        }
      </div>

      <ul class="flex flex-col" data-animate="fade">
        {
          items.map((item, i) => (
            <li class:list={['flex items-center gap-4 py-4', i > 0 && 'border-t border-ink']}>
              <DocumentIcon section={item.section as Section} />
              <div class="flex-1 font-body font-medium text-[22px] text-ink">{item.title}</div>
              {item.fileUrl && (
                <a
                  href={item.fileUrl}
                  class="font-bold text-[18px] text-ink whitespace-nowrap"
                >
                  Download ↓
                </a>
              )}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
  <TornEdge position="bottom" color="var(--color-accent-sage)" />
</div>
