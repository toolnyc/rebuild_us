---
import SectionMarker from '../SectionMarker.astro';
import RichText from '../RichText.astro';

interface ResourceItem {
  title?: string;
  format?: string;
  fileUrl?: string | null;
}

interface Props {
  label?: string;
  headline?: string;
  subcopy?: any;
  leftCopy?: string;
  items?: ResourceItem[];
  resourcesPageVisible?: boolean;
}

const {
  label,
  headline,
  subcopy,
  leftCopy,
  items = [],
  resourcesPageVisible = false,
} = Astro.props;

const iconColors = ['#F4552A', '#A7B795', '#ECF278'];

const leftCopyHtml =
  leftCopy && resourcesPageVisible
    ? leftCopy.replace(
        /rebuild\.us\/resources/,
        '<a href="/resources" class="link-main">rebuild.us/resources</a>'
      )
    : leftCopy;
---

<section id="resources" class="scroll-mt-20 mx-auto max-w-7xl px-6 py-20 lg:py-28">
  <SectionMarker number="05" label={label} class="mb-10 text-ink" />
  <div class="grid gap-12 lg:grid-cols-2">
    <div>
      {headline && <h2 class="ty-h1">{headline}</h2>}
      <div class="mt-6 ty-lead text-ink [&_mark]:box-decoration-clone">
        <RichText value={subcopy} />
      </div>
      {leftCopyHtml && <p class="mt-6 ty-body text-muted" set:html={leftCopyHtml} />}
    </div>

    <ul class="flex flex-col gap-4">
      {
        items.map((item, i) => (
          <li class="flex items-center gap-4 border-b border-ink/10 pb-4">
            <span
              class="flex h-12 w-10 items-end justify-center pb-1 ty-caption font-bold text-ink"
              style={`background-color:${iconColors[i % iconColors.length]}`}
            >
              {item.format ?? 'PDF'}
            </span>
            <div class="flex-1">
              <div class="ty-eyebrow text-muted pb-2">
                Guide 0{i + 1} · {item.format ?? 'PDF'}
              </div>
              <div class="ty-h3">{item.title}</div>
            </div>
            {item.fileUrl && (
              <a href={item.fileUrl} class="link-alt ty-body font-semibold">
                Download ↓
              </a>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</section>
