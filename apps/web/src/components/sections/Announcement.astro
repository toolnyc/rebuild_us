---
interface Props {
  text?: string;
  ctaLabel?: string;
  destination?: string;
}

const { text, ctaLabel, destination = '#join' } = Astro.props;
---

<div data-announcement class="bg-accent-orange text-white">
  <div class="mx-auto flex max-w-7xl flex-wrap items-center justify-center gap-x-2 gap-y-0.5 px-4 py-1.5 text-center font-ui text-xs sm:px-6 sm:py-2 sm:text-sm">
    <span>{text}</span>
    {
      ctaLabel && (
        <a href={destination} class="font-semibold underline underline-offset-2">
          {ctaLabel}
        </a>
      )
    }
  </div>
</div>
