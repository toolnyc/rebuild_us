---
import Logo from '../Logo.astro';

interface Props {
  joinDestination?: string;
  showGive?: boolean;
  visibility?: Record<string, boolean>;
}

const { joinDestination = '#join', showGive = false, visibility = {} } = Astro.props;
---

<!--
  clip-path carves the triangle notch directly out of the orange band —
  no overlay SVG, so there's no sub-pixel gap at the top edge.
  Triangle: 79px wide, 42px tall, starting at 10% from left.
-->
<footer
  class="bg-accent-orange relative"
  style="clip-path: polygon(0% 0%, 10% 0%, calc(10% + 39.5px) 42px, calc(10% + 79px) 0%, 100% 0%, 100% 100%, 0% 100%);"
>
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-4 px-6 py-16" data-animate="fade">
    <a href="/"><Logo class="h-24 sm:h-32 w-auto" /></a>
  </div>

  <div class="border-t border-ink/30 w-full">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-2 px-6 py-6 ty-caption text-ink sm:flex-row">
      <span>© 2026 Rebuild — The National Disaster Survivors Association</span>
      <div class="flex items-center gap-4">
        {
          visibility.privacyPage && (
            <a href="/privacy" class="hover:underline">
              Privacy Policy
            </a>
          )
        }
        {
          visibility.contactPage && (
            <a href="/contact" class="hover:underline">
              Contact
            </a>
          )
        }
        <a
          href="https://rebuild-us.sanity.studio"
          target="_blank"
          rel="noopener"
          class="hover:underline"
        >
          Edit
        </a>
      </div>
    </div>
  </div>
</footer>
