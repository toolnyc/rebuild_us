---
import Button from '../Button.astro';
import Logo from '../Logo.astro';

interface Props {
  joinDestination?: string;
  showGive?: boolean;
  visibility?: Record<string, boolean>;
}

const { joinDestination = '#join', showGive = false, visibility = {} } = Astro.props;

const getInvolved = [
  showGive && { href: 'https://donate.rebuild.us', label: 'Donate' },
  visibility.memberPortalPage && { href: '/member-portal', label: 'Member Portal' },
  visibility.contactPage && { href: '/contact', label: 'Contact' },
].filter(Boolean) as { href: string; label: string }[];

const explore = [
  visibility.caseStudiesPage && { href: '/case-studies', label: 'Case Studies' },
  visibility.aboutPage && { href: '/about', label: 'More Information' },
].filter(Boolean) as { href: string; label: string }[];

const columns = [
  getInvolved.length > 0 && { title: 'Get involved', links: getInvolved },
  explore.length > 0 && { title: 'Explore', links: explore },
].filter(Boolean) as { title: string; links: { href: string; label: string }[] }[];
---

<footer class="bg-ink text-white">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-6 px-6 py-16">
    <div class="flex flex-col items-center gap-6">
      <Logo invert />
      <Button href={joinDestination}>Join Rebuild →</Button>
    </div>

    {
      columns.length > 0 && (
        <div class="mt-6 flex flex-wrap justify-center gap-x-16 gap-y-8 text-left">
          {columns.map((col) => (
            <div>
              <div class="font-ui text-xs uppercase tracking-widest text-white/50">{col.title}</div>
              <ul class="mt-4 flex flex-col gap-2 font-ui text-base">
                {col.links.map((l) => (
                  <li>
                    <a href={l.href} class="link-alt">
                      {l.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      )
    }
  </div>

  <div class="border-t border-white/10">
    <div class="mx-auto flex max-w-7xl flex-col items-center justify-between gap-2 px-6 py-6 font-ui text-xs text-white/50 sm:flex-row">
      <span>© 2026 Rebuild — The National Disaster Survivors Association</span>
      <div class="flex items-center gap-4">
        {
          visibility.privacyPage && (
            <a href="/privacy" class="hover:text-accent-orange">
              Privacy Policy
            </a>
          )
        }
        <span>By &amp; for survivors</span>
      </div>
    </div>
  </div>
</footer>
