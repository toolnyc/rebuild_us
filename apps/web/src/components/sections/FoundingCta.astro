---
import SectionMarker from '../SectionMarker.astro';

interface Props {
  label?: string;
  headline?: string;
  subcopy?: string;
  formSrc?: string;
}

const {
  label,
  headline,
  subcopy,
  formSrc = 'https://act.rebuild.us/founding-member/embed',
} = Astro.props;
---

<section id="join" class="scroll-mt-20 bg-ink text-white">
  <div class="mx-auto grid max-w-7xl gap-12 px-6 py-20 lg:grid-cols-2 lg:items-center lg:py-28">
    <div>
      <SectionMarker number="03" label={label} class="mb-8 text-white" />
      {headline && <h2 class="font-display text-4xl leading-tight lg:text-5xl">{headline}</h2>}
      {subcopy && <p class="mt-6 max-w-md text-lg text-white/70">{subcopy}</p>}
    </div>
    <div>
      <iframe
        data-st-embed
        src={formSrc}
        allow="payment *"
        style="width:100%;border:none;min-height:500px;transition:height 0.35s ease;"
        title="Become a Founding Member"></iframe>
    </div>
  </div>
</section>
