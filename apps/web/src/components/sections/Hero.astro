---
import Button from '../Button.astro';
import { urlFor } from '../../lib/sanity';

interface Props {
  headline?: string;
  headlineAccent?: string;
  subcopy?: string;
  image?: any;
  imageAlt?: string;
  caption?: string;
  joinDestination?: string;
}

const {
  headline,
  headlineAccent,
  subcopy,
  image,
  imageAlt,
  caption,
  joinDestination = '#join',
} = Astro.props;

const imageUrl = image ? urlFor(image).width(1200).height(1400).fit('crop').url() : null;
---

<section id="top" class="mx-auto grid max-w-7xl gap-12 px-6 py-16 lg:grid-cols-2 lg:items-center lg:py-24">
  <div>
    <div class="mb-6 font-ui text-xs uppercase tracking-widest text-muted">Est. 2026 — National</div>
    <h1 class="font-display text-5xl leading-[1.05] sm:text-6xl lg:text-7xl">
      {headline}{' '}
      {headlineAccent && <em class="italic text-accent-orange">{headlineAccent}</em>}
    </h1>
    {subcopy && <p class="mt-6 max-w-xl text-lg text-muted">{subcopy}</p>}
    <div class="mt-8 flex flex-wrap items-center gap-6">
      <Button href={joinDestination} size="lg">Join Rebuild</Button>
    </div>
  </div>

  <div class="relative">
    <div class="absolute -bottom-4 -left-4 h-2/3 w-2/3 bg-accent-yellow" aria-hidden="true"></div>
    <figure class="relative">
      {
        imageUrl ? (
          <img src={imageUrl} alt={imageAlt ?? ''} class="aspect-[6/7] w-full object-cover" />
        ) : (
          <div class="flex aspect-[6/7] w-full items-center justify-center bg-muted/20 font-ui text-sm text-muted">
            Hero photo
          </div>
        )
      }
      {
        caption && (
          <figcaption class="absolute bottom-4 left-4 bg-ink/80 px-3 py-1 font-ui text-xs text-white">
            {caption}
          </figcaption>
        )
      }
    </figure>
  </div>
</section>
