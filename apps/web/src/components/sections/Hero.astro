---
import Button from '../Button.astro';
import { urlFor } from '../../lib/sanity';

interface Props {
  headline?: string;
  headlineAccent?: string;
  subcopy?: string;
  image?: any;
  imageAlt?: string;
  joinDestination?: string;
}

const {
  headline,
  headlineAccent,
  subcopy,
  image,
  imageAlt,
  joinDestination = '#join',
} = Astro.props;

const imageUrl = image ? urlFor(image).width(1200).height(1400).fit('crop').url() : null;
---

<section
  id="top"
  class="mx-auto grid max-w-7xl gap-12 px-6 py-16 lg:grid-cols-2 lg:items-center lg:py-24"
  data-animate="hero"
>
  <div>
    <h1 class="ty-display">
      {headline}{' '}
      {headlineAccent && <em>{headlineAccent}</em>}
    </h1>
    {subcopy && <p class="mt-6 max-w-xl ty-lead">{subcopy}</p>}
    <div class="mt-8 flex flex-wrap items-center gap-6">
      <Button href={joinDestination} variant="primary" size="lg">Join Rebuild</Button>
    </div>
  </div>

  <div class="relative lg:-mb-16 lg:z-10">
    {
      imageUrl ? (
        <img
          src={imageUrl}
          alt={imageAlt ?? ''}
          class="w-full object-cover rounded-[var(--radius)]"
          style="aspect-ratio:6/7;"
        />
      ) : (
        <div
          class="flex w-full items-center justify-center bg-muted/20 ty-body text-muted rounded-[var(--radius)]"
          style="aspect-ratio:6/7;"
        >
          Hero photo
        </div>
      )
    }
  </div>
</section>
