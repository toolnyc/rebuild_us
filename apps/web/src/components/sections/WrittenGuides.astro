---
import DocumentIcon from '../DocumentIcon.astro';

interface Guide {
  title?: string;
  section?: string;
  fileUrl?: string | null;
}

interface Props {
  heading?: string;
  subcopy?: string;
  guides?: Guide[];
}

const { heading = 'Written Guides', subcopy, guides = [] } = Astro.props;

type SectionKey = 'disaster-tipsheets' | 'survivors-communities' | 'fema-government' | 'insurance';

const SECTION_LABELS: Record<SectionKey, string> = {
  'disaster-tipsheets': 'Disaster Tipsheets',
  'survivors-communities': 'For Survivors & Our Communities',
  'fema-government': 'FEMA & Government Programs',
  'insurance': 'Insurance',
};

const SECTION_ORDER: SectionKey[] = [
  'disaster-tipsheets',
  'survivors-communities',
  'fema-government',
  'insurance',
];

const grouped = SECTION_ORDER.map((key) => ({
  key,
  label: SECTION_LABELS[key],
  items: guides.filter((g) => g.section === key),
}));
---

<section id="guides" class="scroll-mt-20 mx-auto max-w-7xl px-6 py-20 lg:py-28">
  <div class="mt-12 grid gap-8 grid-cols-1 lg:grid-cols-2">
    {
      grouped.map((col) => (
        <div
          class="border-2 border-accent-sage rounded-[var(--radius)] bg-white p-8"
          data-animate="fade"
        >
          <h3 class="ty-h2 mb-6">{col.label}</h3>
          <div class="flex flex-col gap-5">
            {col.items.length === 0 && (
              <p class="ty-body text-muted">No guides yet.</p>
            )}
            {col.items.map((guide) => (
              <a
                href={guide.fileUrl ?? '#'}
                class="flex items-center gap-4 group"
                aria-label={guide.title}
                {...(!guide.fileUrl && { 'aria-disabled': 'true', tabIndex: -1 })}
              >
                <DocumentIcon section={col.key} />
                <span class="ty-body font-bold group-hover:text-accent-orange transition-colors">
                  {guide.title}
                </span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
