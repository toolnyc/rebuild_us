---
import DocumentIcon from '../DocumentIcon.astro';

interface Guide {
  title?: string;
  section?: string;
  fileUrl?: string | null;
}

interface Props {
  guides?: Guide[];
}

const { guides = [] } = Astro.props;

type SectionKey = 'disaster-tipsheets' | 'survivors-communities' | 'fema-government' | 'insurance';

const SECTION_LABELS: Record<SectionKey, string> = {
  'disaster-tipsheets': 'Disaster Tipsheets',
  'survivors-communities': 'For Survivors & Our Communities',
  'fema-government': 'FEMA & Government Programs',
  'insurance': 'Insurance',
};

const SECTION_ORDER: SectionKey[] = [
  'disaster-tipsheets',
  'fema-government',
  'survivors-communities',
  'insurance',
];

const grouped = SECTION_ORDER.map((key) => ({
  key,
  label: SECTION_LABELS[key],
  items: guides.filter((g) => g.section === key),
}));
---

<section id="guides" class="scroll-mt-20 px-6 pt-16 pb-8 lg:pt-24 lg:pb-10">
  <div class="mx-auto max-w-7xl space-y-16">
    {
      grouped.map((section) => (
        <div data-animate="fade">
          <h2 class="ty-h2 mb-8">{section.label}</h2>
          <div class="grid gap-4 grid-cols-1 sm:grid-cols-2 lg:grid-cols-3">
            {section.items.length === 0 && (
              <p class="ty-body text-muted col-span-full">No guides yet.</p>
            )}
            {section.items.map((guide) => (
              <a
                href={guide.fileUrl ?? '#'}
                class:list={[
                  'flex items-center gap-4 border border-ink/20 rounded-[var(--radius)] p-5 transition-colors',
                  guide.fileUrl
                    ? 'hover:border-ink/50 group cursor-pointer'
                    : 'pointer-events-none opacity-50',
                ]}
                aria-label={guide.title}
                {...(!guide.fileUrl && { 'aria-disabled': 'true', tabIndex: -1 })}
              >
                <DocumentIcon section={section.key} />
                <span class="ty-body font-bold flex-1 group-hover:text-accent-orange transition-colors">
                  {guide.title}
                </span>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </div>
</section>
