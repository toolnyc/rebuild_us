---
import SectionMarker from '../SectionMarker.astro';
import RichText from '../RichText.astro';

interface Props {
  label?: string;
  statement?: any;
  support?: string;
}

const { label, statement, support } = Astro.props;
---

<section id="about" class="mx-auto max-w-7xl px-6 py-20 lg:py-28">
  <SectionMarker number="02" label={label} class="mb-10 text-ink" />
  <div class="ty-h1 max-w-4xl [&_mark]:box-decoration-clone">
    <RichText value={statement} />
  </div>
  {
    support && (
      <p class="mt-10 max-w-xl border-l-2 border-accent-orange pl-5 ty-body text-muted">
        {support}
      </p>
    )
  }
</section>
