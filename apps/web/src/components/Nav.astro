---
import Button from './Button.astro';
import Logo from './Logo.astro';

interface Props {
  showGive?: boolean;
  joinDestination?: string;
  resourcesDestination?: string;
}

const {
  showGive = false,
  joinDestination = '#join',
  resourcesDestination = '#resources',
} = Astro.props;
---

<header class="border-b border-ink/10 bg-white/95 backdrop-blur">
  <nav class="mx-auto grid max-w-7xl grid-cols-3 items-center px-4 py-3 sm:px-6 sm:py-4">
    <div class="flex justify-start">
      <a href={resourcesDestination} class="ty-eyebrow text-accent-orange">Resources</a>
    </div>

    <a href="/" aria-label="Rebuild home" class="mx-auto w-fit">
      <Logo />
    </a>

    <div class="flex items-center justify-end gap-4">
      {showGive && (
        <a href="https://donate.rebuild.us" class="link-alt text-sm">GIVE</a>
      )}
      <Button href={joinDestination} variant="small">Join</Button>
    </div>
  </nav>
</header>
