---
import Button from './Button.astro';
import Logo from './Logo.astro';

interface Props {
  showGive?: boolean;
  joinDestination?: string;
  resourcesDestination?: string;
}

const {
  showGive = false,
  joinDestination = '#join',
  resourcesDestination = '#resources',
} = Astro.props;
---

<header class="border-b border-ink/10 bg-cream/95 backdrop-blur">
  <nav class="mx-auto grid max-w-7xl grid-cols-3 items-center px-6 py-4">
    <div class="flex justify-start font-ui text-base">
      <a href={resourcesDestination} class="link-alt">Resources</a>
    </div>

    <a href="#top" aria-label="Rebuild home" class="mx-auto w-fit">
      <Logo />
    </a>

    <div class="flex items-center justify-end gap-6 font-ui text-base">
      {
        showGive && (
          <a href="https://donate.rebuild.us" class="link-alt">
            GIVE
          </a>
        )
      }
      <Button href={joinDestination} size="sm">Join</Button>
    </div>
  </nav>
</header>
