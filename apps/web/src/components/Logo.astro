---
interface Props {
  invert?: boolean;
  class?: string;
}

const { invert = false, class: className = '' } = Astro.props;
---

<img
  src={invert ? '/images/logo-lockup-white.png' : '/images/logo-lockup-black.png'}
  alt="Rebuild — The National Disaster Survivors Association"
  class:list={['h-10 w-auto sm:h-14', className]}
/>
