---
interface Props {
  number: string;
  label?: string;
  class?: string;
}

const { number, label, class: className = '' } = Astro.props;
---

<div class={`section-marker flex items-center gap-3 ty-eyebrow ${className}`}>
  <span class="font-semibold">N°{number}</span>
  {label && <span class="opacity-70">{label}</span>}
</div>
