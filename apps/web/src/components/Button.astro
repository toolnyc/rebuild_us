---
interface Props {
  href: string;
  variant?: 'primary' | 'outline' | 'dark' | 'small' | 'main' | 'alt';
  size?: 'sm' | 'base' | 'lg';
  class?: string;
  [key: string]: any;
}

const { href, variant = 'primary', size = 'base', class: className = '', ...rest } = Astro.props;

// Map legacy variant names
const resolvedVariant = variant === 'main' ? 'primary' : variant === 'alt' ? 'outline' : variant;

const base = 'inline-flex items-center justify-center font-bold transition'
  + ' rounded-[var(--radius)]'
  + ' font-body';

const sizes = {
  sm: 'px-4 py-1.5 text-sm',
  base: 'px-6 py-3 text-base',
  lg: 'px-8 py-4 text-lg',
};

const variants = {
  primary: 'bg-accent-orange text-white hover:opacity-90',
  outline: 'border border-ink text-ink hover:bg-ink hover:text-white',
  dark: 'bg-ink text-white hover:opacity-90',
  small: 'border-2 border-accent-orange bg-accent-orange text-white text-[0.875rem] font-bold px-3 py-1 hover:bg-transparent hover:text-accent-orange',
};

const sizeClass = resolvedVariant === 'small' ? '' : sizes[size];
const variantClass = variants[resolvedVariant] ?? variants.primary;
---

<a href={href} class:list={[base, sizeClass, variantClass, className]} {...rest}>
  <slot />
</a>
