---
import { PortableText } from 'astro-portabletext';
import type { PortableTextProps } from 'astro-portabletext/types';
import Highlight from './Highlight.astro';

interface Props {
  value: PortableTextProps['value'];
}

const { value } = Astro.props;
---

{
  value && (
    <PortableText
      value={value}
      components={{
        mark: {
          highlight: Highlight,
        },
      }}
    />
  )
}
