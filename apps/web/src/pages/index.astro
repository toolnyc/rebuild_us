---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Announcement from '../components/sections/Announcement.astro';
import Hero from '../components/sections/Hero.astro';
import Stats from '../components/sections/Stats.astro';
import About from '../components/sections/About.astro';
import FoundingCta from '../components/sections/FoundingCta.astro';
import WhyJoin from '../components/sections/WhyJoin.astro';
import Resources from '../components/sections/Resources.astro';
import GetInvolved from '../components/sections/GetInvolved.astro';
import Footer from '../components/sections/Footer.astro';
import { sanityClient } from '../lib/sanity';

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

const splash = await sanityClient.fetch(`*[_type == "splashPage"][0]{
  ...,
  resourceItems[]{ title, format, "fileUrl": file.asset->url }
}`);

const visibility = await sanityClient.fetch(`{
  "privacyPage": *[_type == "privacyPage"][0].visible,
  "resourcesPage": *[_type == "resourcesPage"][0].visible,
  "aboutPage": *[_type == "aboutPage"][0].visible,
  "contactPage": *[_type == "contactPage"][0].visible,
  "caseStudiesPage": *[_type == "caseStudiesPage"][0].visible,
  "memberPortalPage": *[_type == "memberPortalPage"][0].visible
}`);

const joinDestination = siteSettings?.joinDestination ?? '#join';
---

<BaseLayout>
  {
    siteSettings?.showAnnouncement && (
      <Announcement
        text={siteSettings?.announcementText}
        ctaLabel={siteSettings?.announcementCtaLabel}
        destination={siteSettings?.announcementDestination}
      />
    )
  }

  <Nav
    showGive={siteSettings?.showGive}
    joinDestination={joinDestination}
    resourcesDestination={siteSettings?.resourcesDestination}
  />

  <main>
    <Hero
      headline={splash?.heroHeadline}
      headlineAccent={splash?.heroHeadlineAccent}
      subcopy={splash?.heroSubcopy}
      image={splash?.heroImage}
      imageAlt={splash?.heroImage?.alt}
      caption={splash?.heroImageCaption}
      joinDestination={joinDestination}
    />

    <Stats />

    <About label={splash?.aboutLabel} statement={splash?.aboutStatement} support={splash?.aboutSupport} />

    <FoundingCta
      label={splash?.foundingLabel}
      headline={splash?.foundingCtaHeadline}
      subcopy={splash?.foundingCtaSubcopy}
      formSrc={siteSettings?.foundingMemberFormSrc}
    />

    <WhyJoin label={splash?.benefitsLabel} columns={splash?.whyJoinColumns} />

    <Resources
      label={splash?.resourcesLabel}
      headline={splash?.resourcesHeadline}
      subcopy={splash?.resourcesSubcopy}
      leftCopy={splash?.resourcesLeftCopy}
      items={splash?.resourceItems}
      resourcesPageVisible={visibility?.resourcesPage}
    />

    <GetInvolved
      copy={splash?.getInvolvedCopy}
      finePrint={splash?.getInvolvedFinePrint}
      formSrc={siteSettings?.getInvolvedFormSrc}
      instagramUrl={siteSettings?.instagramUrl}
      facebookUrl={siteSettings?.facebookUrl}
      youtubeUrl={siteSettings?.youtubeUrl}
    />
  </main>

  <Footer joinDestination={joinDestination} showGive={siteSettings?.showGive} visibility={visibility} />
</BaseLayout>

<script>
import gsap from 'gsap';
import { ScrollTrigger } from 'gsap/ScrollTrigger';

gsap.registerPlugin(ScrollTrigger);

const EASE = 'power2.out';
const DUR  = 0.9;
const Y    = 20;

const fade = (o: gsap.TweenVars = {}): gsap.TweenVars =>
  ({ y: Y, opacity: 0, duration: DUR, ease: EASE, ...o });

const sc = (el: Element) =>
  ({ trigger: el, start: 'top 95%', once: true });

// ── Hero: load-time cascade ──────────────────────────────────────────────
const heroLeft  = document.querySelector('#top > div:first-child');
const heroRight = document.querySelector('#top > div.relative');

if (heroLeft) {
  const eyebrow = heroLeft.querySelector('div');
  const h1      = heroLeft.querySelector('h1');
  const p       = heroLeft.querySelector('p');
  const links   = heroLeft.querySelectorAll('a');
  if (eyebrow) gsap.from(eyebrow, fade({ y: 0, duration: 0.5, delay: 0.1 }));
  if (h1)      gsap.from(h1,      fade({ duration: 1.1, delay: 0.2 }));
  if (p)       gsap.from(p,       fade({ delay: 0.5 }));
  if (links.length) gsap.from(links, fade({ delay: 0.75, stagger: 0.1 }));
}
if (heroRight) gsap.from(heroRight, fade({ delay: 0.35 }));

// ── Stats: trigger as section enters so count-up is live when readable ───
const statSection = document.querySelector('.bg-ink');
const statItems   = document.querySelectorAll('.bg-ink > div > div');

if (statItems.length) {
  gsap.from(statItems, {
    ...fade({ stagger: 0.1 }),
    scrollTrigger: { trigger: statSection ?? statItems[0], start: 'top bottom', once: true },
  });
}
document.querySelectorAll('.bg-ink .font-display').forEach((el) => {
  const num = parseInt(el.textContent ?? '');
  if (!isNaN(num) && num > 1) {
    const proxy = { val: 0 };
    const snap  = el.textContent;
    gsap.to(proxy, {
      val: num, duration: 2, ease: EASE,
      onUpdate()  { el.textContent = String(Math.round(proxy.val)); },
      onComplete() { el.textContent = snap; },
      scrollTrigger: { trigger: statSection ?? el, start: 'top bottom', once: true },
    });
  }
});

// ── Sections: marker → h2 → body copy → staggered lists ─────────────────
interface SectionCfg { marker?: string; h2?: string; body?: string; items?: string }

const sections: SectionCfg[] = [
  { marker: '#about .font-ui.uppercase',               body: '#about .font-display, #about p' },
  { marker: '#join .font-ui.uppercase',                h2: '#join h2',                    body: '#join p, #join iframe' },
  { marker: '#membership-benefits .font-ui.uppercase', h2: '#membership-benefits h2',     items: '#membership-benefits article' },
  { marker: '#resources .font-ui.uppercase',           h2: '#resources h2',               body: '#resources .text-xl', items: '#resources li' },
  {                                                    h2: 'main section:last-of-type h2', body: 'main section:last-of-type p, main section:last-of-type .flex.gap-4, main section:last-of-type iframe' },
];

sections.forEach(({ marker: ms, h2: hs, body: bs, items: is }) => {
  const marker = ms ? document.querySelector(ms) : null;
  const h2     = hs ? document.querySelector(hs) : null;
  const items  = is ? document.querySelectorAll(is) : null;

  if (marker) gsap.from(marker, { ...fade({ x: -16, y: 0 }), scrollTrigger: sc(marker) });
  if (h2)     gsap.from(h2,     { ...fade(),                  scrollTrigger: sc(h2) });
  if (bs) document.querySelectorAll(bs).forEach((el) => {
    gsap.from(el, { ...fade(), scrollTrigger: sc(el) });
  });
  if (items?.length) gsap.from(items, { ...fade({ stagger: 0.1 }), scrollTrigger: sc(items[0]) });
});
</script>
