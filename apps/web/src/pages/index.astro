---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Hero from "../components/sections/Hero.astro";
import Stats from "../components/sections/Stats.astro";
import About from "../components/sections/About.astro";
import FoundingCta from "../components/sections/FoundingCta.astro";
import WhyJoin from "../components/sections/WhyJoin.astro";
import Resources from "../components/sections/Resources.astro";
import GetInvolved from "../components/sections/GetInvolved.astro";
import Footer from "../components/sections/Footer.astro";
import { sanityClient } from "../lib/sanity";

const siteSettings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

const splash = await sanityClient.fetch(`*[_type == "splashPage"][0]{
  ...,
  featuredResources[]->{ title, "fileUrl": file.asset->url }
}`);

const visibility = await sanityClient.fetch(`{
  "privacyPage": *[_type == "privacyPage"][0].visible,
  "resourcesPage": *[_type == "resourcesPage"][0].visible,
  "aboutPage": *[_type == "aboutPage"][0].visible,
  "contactPage": *[_type == "contactPage"][0].visible,
  "caseStudiesPage": *[_type == "caseStudiesPage"][0].visible,
  "memberPortalPage": *[_type == "memberPortalPage"][0].visible
}`);

const joinDestination = siteSettings?.joinDestination ?? "#join";
---

<BaseLayout>
  <!-- Sage top strip, full-width, above everything -->
  <div class="w-full h-[28px] bg-accent-sage"></div>

  <div class="sticky top-0 z-50">
    <Nav
      joinDestination={joinDestination}
      resourcesDestination={siteSettings?.resourcesDestination}
    />
  </div>

  <main>
    <!-- Yellow edge bars: Hero only -->
    <div class="relative">
      <div class="hidden lg:block absolute inset-y-0 left-0 w-[22px] bg-accent-yellow z-10 pointer-events-none" aria-hidden="true"></div>
      <div class="hidden lg:block absolute inset-y-0 right-0 w-[22px] bg-accent-yellow z-10 pointer-events-none" aria-hidden="true"></div>

      <Hero
        headline={splash?.heroHeadline}
        headlineAccent={splash?.heroHeadlineAccent}
        subcopy={splash?.heroSubcopy}
        image={splash?.heroImage}
        imageAlt={splash?.heroImage?.alt}
        joinDestination={joinDestination}
      />
    </div>

    <Stats />

    <About
      label={splash?.aboutLabel}
      statement={splash?.aboutStatement}
      support={splash?.aboutSupport}
    />

    <FoundingCta
      label={splash?.foundingLabel}
      headline={splash?.foundingCtaHeadline}
      subcopy={splash?.foundingCtaSubcopy}
      formSrc={siteSettings?.foundingMemberFormSrc}
      fundraiseUpCampaignId={siteSettings?.fundraiseUpCampaignId}
    />

    <WhyJoin label={splash?.benefitsLabel} columns={splash?.whyJoinColumns} bgImage={splash?.whyJoinBgImage} />

    <Resources
      label={splash?.resourcesLabel}
      headline={splash?.resourcesHeadline}
      subcopy={splash?.resourcesSubcopy}
      leftCopy={splash?.resourcesLeftCopy}
      items={splash?.featuredResources}
      resourcesPageVisible={visibility?.resourcesPage}
    />

    <GetInvolved
      copy={splash?.getInvolvedCopy}
      finePrint={splash?.getInvolvedFinePrint}
      formSrc={siteSettings?.getInvolvedFormSrc}
      instagramUrl={siteSettings?.instagramUrl}
      facebookUrl={siteSettings?.facebookUrl}
      youtubeUrl={siteSettings?.youtubeUrl}
    />
  </main>

  <Footer
    joinDestination={joinDestination}
    visibility={visibility}
  />
</BaseLayout>

<script>
  import gsap from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";
  import Lenis from "lenis";
  import { setupMotion } from "../scripts/motion";

  gsap.registerPlugin(ScrollTrigger);

  const lenis = new Lenis({ lerp: 0.12 });
  lenis.on("scroll", ScrollTrigger.update);
  gsap.ticker.add((time) => lenis.raf(time * 1000));
  gsap.ticker.lagSmoothing(0);

  const stickyHeader = document.querySelector(".sticky") as HTMLElement | null;
  const headerOffset = () => -((stickyHeader?.offsetHeight ?? 80) + 16);

  document.querySelectorAll('a[href^="#"]').forEach((link) => {
    link.addEventListener("click", (e) => {
      const id = link.getAttribute("href");
      if (!id || id === "#") return;
      const target = document.querySelector(id);
      if (!target) return;
      e.preventDefault();
      lenis.scrollTo(target as HTMLElement, { offset: headerOffset() });
    });
  });

  // Announcement banner: pops in after the hero cascade settles
  const announcement = document.querySelector("[data-announcement]");
  if (announcement) {
    gsap.from(announcement, {
      autoAlpha: 0,
      duration: 0.6,
      ease: "power3.out",
      delay: 1.4,
      clearProps: "opacity,visibility",
    });
  }

  setupMotion({ page: "splash" });
</script>
